@startuml architecture
skinparam backgroundColor white
skinparam defaultFontName monospaced
skinparam shadowing false

title claude-peers: Fleet Architecture

node "ubuntu-homelab (broker machine)" as homelab {
  [Broker :7899] as broker
  database "SQLite" as db
  queue "NATS JetStream\n:4222" as nats
  [Dream Watch] as dream
  [Supervisor] as super

  broker -down-> db : persist
  broker -down-> nats : publish events
  dream -down-> nats : subscribe fleet.>
  super -down-> nats : trigger daemons
}

cloud "LiteLLM :4000" as litellm {
  [Claude Opus/Sonnet] as claude_models
  [Qwen 9B local] as qwen
}

super ..> litellm : daemon workflows

node "omarchy" as om {
  [Claude Code] as cc1
  [MCP Server] as mcp1
  cc1 -down-> mcp1 : stdio
}

node "macbook1" as mb {
  [Claude Code] as cc2
  [MCP Server] as mcp2
  cc2 -down-> mcp2 : stdio
}

node "thinkbook" as tb {
  [Claude Code] as cc3
  [MCP Server] as mcp3
  cc3 -down-> mcp3 : stdio
}

node "raspdeck" as rp {
  [Claude Code] as cc4
  [MCP Server] as mcp4
  [Gridwatch\nDashboard] as gw
  cc4 -down-> mcp4 : stdio
}

mcp1 --> broker : register / heartbeat\nsend + poll messages
mcp2 --> broker : Tailscale
mcp3 --> broker : Tailscale
mcp4 --> broker : Tailscale
gw --> broker : poll peers + events

note right of mcp1
  --dangerously-load-development-channels
  Required for live message delivery.
  Messages arrive via channel notification
  directly into Claude's session.
end note

note bottom of dream
  Writes fleet-activity.md
  to Claude memory path.
  Every new session knows
  what the fleet was doing.
end note

note bottom of super
  4 daemons: fleet-scout,
  pr-helper, llm-watchdog,
  fleet-memory. Policy-
  constrained, auto-triggered.
end note
@enduml
