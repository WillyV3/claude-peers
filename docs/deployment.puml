@startuml Fleet Deployment
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #1a1a2e
skinparam defaultFontName "Helvetica"
skinparam nodeFontSize 12
skinparam componentFontSize 10
skinparam noteFontSize 9
skinparam arrowColor #555577
skinparam rectangleBorderColor #ccccdd
skinparam nodeBorderColor #ccccdd
skinparam shadowing false

title <b>FLEET DEPLOYMENT</b>\nPhysical machines on Tailscale mesh

cloud "Tailscale VPN\n<color:#666>Encrypted mesh</color>" as tailscale #f4f8ff {

  node "ubuntu-homelab\n<color:#666>100.109.211.128</color>\n<color:#666>Ubuntu 24.04 | 32GB</color>" as homelab #f4fff0 {
    component "[Trust Broker]\n:7899" as broker #e4f0e8
    component "[NATS Server]\n:4222" as nats #e0f0ff
    component "[Supervisor]" as supervisor #e4f0e8
    component "[Dream Watch]" as dream #e4f0e8
    component "[Wazuh Bridge]" as wbridge #f4e0e0
    component "[Wazuh Manager]\n:1514 :55000\n<color:#666>Docker</color>" as wazuh #f4e0e0
    component "[LiteLLM Proxy]\n:4000\n<color:#666>Docker</color>" as litellm #e8ecf4
    database "SQLite" as db #e4f0e8
  }

  node "omarchy\n<color:#666>100.85.150.110</color>\n<color:#666>Arch | N100 | 16GB</color>" as omarchy #f0f4ff {
    component "[Claude Code]\nMCP + Peers" as cc1 #e8ecf4
    component "[Wazuh Agent]" as wa1 #f4e0e0
  }

  node "thinkbook\n<color:#666>100.119.90.27</color>\n<color:#666>Arch | i5 | 8GB</color>" as thinkbook #f0f4ff {
    component "[Claude Code]\nMCP + Peers" as cc2 #e8ecf4
    component "[Wazuh Agent]" as wa2 #f4e0e0
  }

  node "raspdeck\n<color:#666>Pi 5 | 16GB</color>" as raspdeck #f0f8ff {
    component "[Gridwatch]\n:8888\n<color:#666>5-page kiosk</color>" as gridwatch #e0ecf4
    component "[Claude Code]" as cc3 #e8ecf4
    component "[Wazuh Agent]" as wa3 #f4e0e0
  }

  node "willyv4\n<color:#666>100.95.2.57</color>\n<color:#666>Pi Zero 2W | 512MB</color>" as willyv4 #fff8f0 {
    component "[ghostbox]\nVoice agent" as ghost #f4ece0
    component "[Awareness\nEngine]" as aware #f4ece0
  }

  node "macbook1\n<color:#666>100.67.104.73</color>\n<color:#666>MacBook Pro</color>" as macbook #f0f4ff {
    component "[Claude Code]" as cc4 #e8ecf4
    component "[Wazuh Agent]" as wa4 #f4e0e0
  }
}

' Connections
cc1 -[#2d8a4e]-> broker
cc2 -[#2d8a4e]-> broker
cc3 -[#2d8a4e]-> broker
cc4 -[#2d8a4e]-> broker
ghost -[#2d8a4e]-> broker

wa1 -[#cc3333]-> wazuh
wa2 -[#cc3333]-> wazuh
wa3 -[#cc3333]-> wazuh
wa4 -[#cc3333]-> wazuh
wazuh -> wbridge
wbridge -[#cc3333]-> nats

broker -> nats
broker -> db
dream -> nats
supervisor -> litellm
gridwatch -[#3388bb]-> broker
gridwatch -[#3388bb]-> nats

aware -[#0077aa]-> nats : <color:#0077aa>telemetry</color>

note right of homelab
  <b>Services running:</b>
  - Trust Broker (systemd)
  - NATS JetStream (systemd)
  - Daemon Supervisor (systemd)
  - Fleet Memory / Dream (systemd)
  - Wazuh Bridge (systemd)
  - Wazuh Manager (Docker)
  - LiteLLM Proxy (Docker)
end note

note bottom of willyv4
  <b>Cyberdeck:</b>
  Battery-powered
  Whisplay HAT
  4G capable
  No Wazuh (ARMv7)
end note

@enduml
