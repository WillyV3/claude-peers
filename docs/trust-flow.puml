@startuml Trust Flow
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #1a1a2e
skinparam defaultFontName "Helvetica"
skinparam sequenceArrowColor #555577
skinparam sequenceLifeLineBorderColor #ccccdd
skinparam sequenceParticipantBorderColor #ccccdd
skinparam sequenceParticipantBackgroundColor #f8f9fc
skinparam sequenceDividerBackgroundColor #e8ecf4
skinparam shadowing false

title <b>TRUST FLOW</b>\nFrom request to enforcement

participant "Claude Code\nSession" as client #f8f9fc
participant "Trust\nBroker" as broker #f4fff0
participant "UCAN\nValidator" as ucan #e4f0e8
participant "Health\nChecker" as health #e4f0e8
participant "NATS" as nats #e0f0ff
participant "Wazuh\nBridge" as wazuh #fff0f0

== Normal Request ==

client -> broker : POST /list-peers\nAuthorization: Bearer <jwt>
broker -> ucan : Validate(token)
ucan -> ucan : Verify Ed25519 signature
ucan -> ucan : Check expiry (30s leeway)
ucan -> ucan : Verify delegation chain (prf)
ucan -> ucan : Check capability: peer/list
ucan --> broker : <color:#2d8a4e>Claims valid</color>
broker -> health : getMachineHealth(machine)
health --> broker : <color:#2d8a4e>status: healthy</color>
broker --> client : <color:#2d8a4e>200 OK</color> [peer list]

== Security Event ==

wazuh -> nats : <color:#cc3333>fleet.security.fim</color>\nlevel=12 (UCAN credential modified)
nats -> broker : SecurityEvent
broker -> health : updateMachineHealth(+10)
health -> health : score=10 -> <color:#cc3333>quarantined</color>

== Quarantined Request ==

client -> broker : POST /send-message\nAuthorization: Bearer <jwt>
broker -> ucan : Validate(token)
ucan --> broker : <color:#2d8a4e>Claims valid</color>
broker -> health : getMachineHealth(machine)
health --> broker : <color:#cc3333>status: quarantined</color>
broker --> client : <color:#cc3333>403 QUARANTINED</color>

== Recovery ==

actor Operator
Operator -> broker : POST /unquarantine\n{"machine": "compromised-host"}
broker -> health : reset score=0, status=healthy
broker --> Operator : <color:#2d8a4e>200 OK</color>

@enduml
