@startuml Sontara Lattice Architecture
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #1a1a2e
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 11
skinparam nodeFontSize 12
skinparam componentFontSize 11
skinparam noteFontSize 10
skinparam arrowColor #555577
skinparam rectangleBorderColor #ccccdd
skinparam nodeBorderColor #ccccdd
skinparam componentBorderColor #ccccdd
skinparam shadowing false

title <b>SONTARA LATTICE</b>\nClaude-native fleet trust platform

' === AGENT LAYER ===
rectangle "AGENT LAYER" as agents #f0f4ff {
  node "omarchy\n<color:#c75000>Claude Code</color>" as omarchy #f8f9fc {
    component "MCP Server" as mcp1 #e8ecf4
    component "UCAN: peer-session" as ucan1 #e8ecf4
  }
  node "thinkbook\n<color:#c75000>Claude Code</color>" as thinkbook #f8f9fc {
    component "MCP Server" as mcp2 #e8ecf4
    component "UCAN: peer-session" as ucan2 #e8ecf4
  }
  node "willyv4\n<color:#c75000>ghostbox</color>" as willyv4 #f8f9fc {
    component "StatusFunc" as status1 #e8ecf4
    component "UCAN: peer-session" as ucan3 #e8ecf4
  }
}

' === DAEMON LAYER ===
rectangle "DAEMON LAYER" as daemons #f0fff4 {
  component "fleet-scout\n<color:#666>interval:15m</color>" as scout #e8f4ec
  component "pr-helper\n<color:#666>interval:30m</color>" as prhelper #e8f4ec
  component "fleet-memory\n<color:#666>event:fleet.></color>" as fmem #e8f4ec
  component "librarian\n<color:#666>interval:6h</color>" as librarian #e8f4ec
  component "sync-janitor\n<color:#666>interval:30m</color>" as janitor #e8f4ec
  component "llm-watchdog\n<color:#666>interval:15m</color>" as watchdog #e8f4ec
}

' === PLATFORM LAYER ===
rectangle "PLATFORM LAYER" as platform #f4fff0 {
  node "ubuntu-homelab" as homelab #f8fcf8 {
    component "Trust Broker\n<color:#2d8a4e>UCAN validation</color>\n<color:#2d8a4e>Peer registry</color>\n<color:#2d8a4e>Health scoring</color>" as broker #e4f0e8
    component "Daemon Supervisor\n<color:#666>Lifecycle management</color>\n<color:#666>Triage + scheduling</color>" as supervisor #e4f0e8
    component "Fleet Memory\n<color:#666>dream-watch</color>" as dream #e4f0e8
    database "SQLite" as db #e4f0e8
  }
}

' === EVENT BUS ===
queue "NATS JetStream\n<color:#0077aa>fleet.peer.*</color>\n<color:#0077aa>fleet.security.*</color>\n<color:#0077aa>fleet.daemon.*</color>" as nats #e0f0ff

' === SECURITY LAYER ===
rectangle "SECURITY LAYER" as security #fff0f0 {
  component "Wazuh Manager\n<color:#666>Docker</color>" as wazuh #f4e0e0
  component "Wazuh Bridge\n<color:#666>alerts.json -> NATS</color>" as bridge #f4e0e0
  collections "Wazuh Agents" as wagents #f4e0e0
}

' === OBSERVABILITY LAYER ===
rectangle "OBSERVABILITY" as observability #f0f8ff {
  node "raspdeck" as raspdeck #f4f8fc {
    component "Gridwatch\n<color:#666>5-page kiosk</color>\n<color:#666>Fleet | Services | NATS</color>\n<color:#666>Daemons | Peers</color>" as gridwatch #e0ecf4
  }
}

' === CONNECTIONS ===
omarchy -[#2d8a4e]-> broker : <color:#2d8a4e>UCAN Bearer</color>
thinkbook -[#2d8a4e]-> broker : <color:#2d8a4e>UCAN Bearer</color>
willyv4 -[#2d8a4e]-> broker : <color:#2d8a4e>UCAN Bearer</color>

supervisor -[#0077aa]-> scout
supervisor -[#0077aa]-> prhelper
supervisor -[#0077aa]-> fmem
supervisor -[#0077aa]-> librarian
supervisor -[#0077aa]-> janitor
supervisor -[#0077aa]-> watchdog

broker -[#0077aa]-> nats : publish
dream -[#0077aa]-> nats : subscribe
scout -[#888]-> broker : fleet-read
prhelper -[#888]-> broker : fleet-write

wagents -[#cc3333]-> wazuh : <color:#cc3333>agent reports</color>
wazuh -[#cc3333]-> bridge
bridge -[#cc3333]-> nats : <color:#cc3333>fleet.security.*</color>
nats -[#cc3333]-> broker : <color:#cc3333>trust demotion</color>

gridwatch -[#3388bb]-> broker : poll
gridwatch -[#3388bb]-> nats : subscribe

broker -[#888]-> db

legend right
  |<color:#2d8a4e> Green </color>| Trust / Auth |
  |<color:#0077aa> Blue </color>| Coordination |
  |<color:#cc3333> Red </color>| Security |
  |<color:#3388bb> Teal </color>| Observability |
  |<color:#c75000> Orange </color>| Claude Code |
endlegend

@enduml
